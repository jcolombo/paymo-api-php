        $output->listItem("List Limit: " . $config->getListLimit() . " items");
    }
    $output->line();

    // Resources by Category
    $output->subHeader("Available Resources");
    $output->listItem("Safe CRUD: Client, Project, Tasklist, Task, Subtask, TimeEntry, etc.");
    $output->listItem("Read-Only: Company, Session, Workflow");
    $output->listItem("Configured Anchor: User, ProjectTemplate, InvoiceTemplate, etc.");
    $output->line();

    // Resource filtering
    $output->subHeader("Resource Filtering");
    $skip = $config->getSkippedResources();
    $only = $config->getOnlyResources();

    if (empty($only)) {
        $output->listItem("Only: (not set - all resources will run)");
    } else {
        $output->listItem("Only: " . implode(', ', $only));
    }

    if (empty($skip)) {
        $output->listItem("Skip: (none)");
    } else {
        $output->listItem("Skip: " . implode(', ', $skip));
    }
    $output->line();

    // Timeouts
    $output->subHeader("Timeouts");
    $timeouts = $config->getTimeouts();
    $output->listItem("Per Test: " . ($timeouts['per_test'] ?? 30) . "s");
    $output->listItem("Per Group: " . ($timeouts['per_group'] ?? 300) . "s");
    $output->listItem("Total: " . ($timeouts['total'] ?? 1800) . "s");
    $output->warning("Note: Timeouts are not currently enforced");
    $output->line();

    // Logging
    $output->subHeader("Logging");
    $logging = $config->getLogging();
    $output->listItem("Enabled: " . ($config->isLoggingEnabled() ? "Yes" : "No"));
    if ($config->isLoggingEnabled()) {
        $output->listItem("Log File: " . $config->getLogPath());
        $output->listItem("Log Level: " . $config->getLogLevel());
        $output->listItem("Include Timestamps: " . ($config->shouldIncludeTimestamps() ? "Yes" : "No"));
        $output->listItem("Include Stack Traces: " . ($config->shouldIncludeStackTraces() ? "Yes" : "No"));
