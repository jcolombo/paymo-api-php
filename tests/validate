function listTests(TestOutput $output): void
{
    $output->header("Available Resources (Resource-Centric Testing)");
    $output->line();
    $output->info("Each resource gets a complete test cycle:");
    $output->info("  - Property Discovery (compare API to SDK PROP_TYPES)");
    $output->info("  - Property Selection (verify each prop can be selected)");
    $output->info("  - CRUD operations (if supported)");
    $output->info("  - Where Operations (filtering)");
    $output->info("  - Include Relationships");
    $output->line();

    $categories = [
        'Safe CRUD (can create and delete)' => [
            'Client', 'Project', 'Tasklist', 'Task', 'Subtask',
            'TimeEntry', 'Milestone', 'Discussion', 'Comment', 'File',
            'Booking', 'Invoice', 'InvoiceItem', 'Estimate', 'EstimateItem',
            'Expense', 'Webhook'
        ],
        'Read-Only' => [
            'Company', 'Session', 'Workflow'
        ],
        'Configured Anchor (require pre-existing IDs)' => [
            'User', 'ProjectTemplate', 'InvoiceTemplate',
            'EstimateTemplate', 'ProjectStatus'
        ],
    ];

    foreach ($categories as $category => $resources) {
        $output->subHeader($category);
        foreach ($resources as $resource) {
            $output->listItem($resource);
        }
        $output->line();
    }

    $output->info("Use 'all' or specify resource names on command line.");
    $output->info("Use 'resources.only' in config to limit scope.");
}

function interactiveStartup(TestConfig $config, TestOutput $output, array &$resources): bool
{
    $output->banner();

    // Show read-only mode status
    if ($config->isReadOnlyMode()) {
        $output->success("*** READ-ONLY MODE ***");
        $output->success("No Create/Update/Delete operations will be performed.");
        $output->success("List operations limited to " . $config->getListLimit() . " items.");
        $output->info("Safe to run against production databases.");
        $output->line();
    } else {
        // Show warning
        $output->warning("This will make API calls to your Paymo account.");
        $output->line();
    }

    // Check API key first
    $apiKey = $config->getApiKey();
    if (!$apiKey) {
        $output->error("API Key: NOT CONFIGURED");
        $output->error("Cannot proceed without API key.");
        return false;
    }

    // Show configured anchors
    $output->subHeader("Configured Anchors");
    $anchors = $config->getAnchors();
    $anchorLabels = [
        'client_id' => 'Client',
        'user_id' => 'User',
        'project_id' => 'Project',
        'project_template_id' => 'Project Template',
        'invoice_template_id' => 'Invoice Template',
        'estimate_template_id' => 'Estimate Template',
        'project_status_id' => 'Project Status',
        'workflow_id' => 'Workflow',
    ];

    $hasAnchors = false;
    foreach ($anchorLabels as $key => $label) {
        if (!empty($anchors[$key])) {
            $output->success("{$label}: #{$anchors[$key]}");
            $hasAnchors = true;
        }
    }
    if (!$hasAnchors) {
        $output->warning("No anchors configured - all dependencies will be created temporarily");
    }
    $output->line();

    // Determine resources to test
    $only = $config->getOnlyResources();
    $skip = $config->getSkippedResources();

    if (!empty($only)) {
        $output->info("Config limits testing to: " . implode(', ', $only));
    }
    if (!empty($skip)) {
        $output->info("Config skips: " . implode(', ', $skip));
    }
    $output->line();

    // Ask user what to test
    $output->subHeader("Select Resources to Test");
    $output->info("Options:");
    $output->listItem("ENTER = Run configured resources" . (!empty($only) ? " (" . implode(', ', $only) . ")" : " (all)"));
    $output->listItem("Type resource names (comma-separated) to test specific ones");
    $output->listItem("'q' = Quit");
    $output->line();
    echo "Your choice: ";

    $input = trim(fgets(STDIN));

    if (strtolower($input) === 'q') {
        return false;
    }

    // Parse user input for specific resources
    if (!empty($input) && strtolower($input) !== 'all') {
        $resources = array_map('trim', explode(',', $input));
    }
    // else $resources stays as passed in (empty = use config filtering)

    // In read-only mode, skip dependency analysis (no resources will be created)
    if ($config->isReadOnlyMode()) {
        $output->line();
        $output->subHeader("Read-Only Mode Summary");
        $output->success("No resources will be created, updated, or deleted.");
        $output->info("Tests will use existing resources from your Paymo account.");
        $output->info("List operations limited to " . $config->getListLimit() . " items per resource.");
        $output->line();

        $output->success("Proceeding with read-only tests...");
        $output->line();
        return true;
    }

    // Now analyze dependencies (only in non-read-only mode)
    $analyzer = new DependencyAnalyzer($config);
    $analysis = $analyzer->analyze($resources);
    $summary = $analyzer->getSummary($analysis);

    $output->line();
    $output->subHeader("Dependency Analysis");

    // Show what will be tested
    $output->info("Resources to test: " . count($analysis['resources_to_test']));
    foreach ($analysis['resources_to_test'] as $res) {
        $deps = $analysis['dependencies'][$res] ?? [];
        if (empty($deps)) {
            $output->listItem("{$res} (no dependencies)");
        } else {
            $output->listItem("{$res} → requires: " . implode(', ', $deps));
        }
    }
    $output->line();

    // Show what anchors will be used
    if (!empty($analysis['will_use_anchors'])) {
        $output->subHeader("Will Use Existing (Anchored) Resources");
        foreach ($analysis['will_use_anchors'] as $resource => $id) {
            $output->success("{$resource} #{$id} (from config)");
        }
        $output->line();
    }

    // Show what will be created temporarily
    if (!empty($analysis['will_create'])) {
        $output->subHeader("Will Create Temporarily (then cleanup)");
        foreach ($analysis['will_create'] as $resource) {
            // Show what it will be attached to
            $deps = DependencyAnalyzer::getDirectDependencies($resource);
            if (!empty($deps)) {
                $attachedTo = [];
                foreach ($deps as $dep) {
                    if (isset($analysis['will_use_anchors'][$dep])) {
                        $attachedTo[] = "{$dep} #{$analysis['will_use_anchors'][$dep]}";
                    } else {
                        $attachedTo[] = "{$dep} (also temporary)";
                    }
                }
                $output->warning("{$resource} → attached to: " . implode(', ', $attachedTo));
            } else {
                $output->warning("{$resource} (top-level, will be deleted)");
            }
        }
        $output->line();
    }

    // Show what cannot be tested
    if (!empty($analysis['cannot_test'])) {
        $output->subHeader("Cannot Test (missing required anchors)");
        foreach ($analysis['cannot_test'] as $resource => $missing) {
            $output->error("{$resource} - needs: " . implode(', ', $missing));
        }
        $output->line();

        // Suggest adding anchors
        if (!empty($analysis['missing_anchors'])) {
            $output->info("To test these resources, add these anchors to your config:");
            foreach ($analysis['missing_anchors'] as $resource => $anchorKey) {
                if ($anchorKey) {
                    $output->listItem("\"{$anchorKey}\": <id>  // for {$resource}");
                }
            }
            $output->line();
        }
    }

    // Final confirmation with clear summary
    $output->subHeader("Summary of API Operations");
    $testCount = count($analysis['resources_to_test']);
    $createCount = count($analysis['will_create']);
    $anchorCount = count($analysis['will_use_anchors']);

    $output->info("• Testing {$testCount} resource(s)");
    if ($anchorCount > 0) {
        $output->info("• Using {$anchorCount} anchored resource(s) from config");
    }
    if ($createCount > 0) {
        $output->warning("• Will CREATE {$createCount} temporary resource(s)");
        $output->warning("• All temporary resources will be DELETED after tests");
    }
    $output->line();

    // Offer options if we're creating things
    if ($createCount > 0) {
        $output->info("Options:");
        $output->listItem("ENTER = Proceed (create temporary resources, cleanup after)");
        $output->listItem("'a' = Add project_id anchor to use existing project for child resources");
        $output->listItem("'q' = Quit");
        echo "Your choice: ";

        $confirm = trim(fgets(STDIN));

        if (strtolower($confirm) === 'q') {
            return false;
        }

        if (strtolower($confirm) === 'a') {
            // Prompt for project_id
            echo "Enter Project ID to use as anchor: ";
            $projectId = trim(fgets(STDIN));
            if (is_numeric($projectId) && (int)$projectId > 0) {
                $config->setAnchor('project_id', (int)$projectId);
                $output->success("Project #{$projectId} set as anchor for this session");

                // Re-analyze with new anchor
                $analysis = $analyzer->analyze($resources);
                $createCount = count($analysis['will_create']);
                $output->info("Updated: Will now create {$createCount} temporary resource(s)");
            }
            $output->line();
        }
    }

    $output->success("Proceeding with tests...");
    $output->line();

    return true;
}
