function applyOverrides(TestConfig $config, array $options): void
{
    if (isset($options['k'])) {
        $config->setApiKey($options['k']);
    } elseif (isset($options['api-key'])) {
        $config->setApiKey($options['api-key']);
    }

    $anchorOverrides = [
        'client-id' => 'client_id',
        'user-id' => 'user_id',
        'project-template-id' => 'project_template_id',
        'invoice-template-id' => 'invoice_template_id',
        'estimate-template-id' => 'estimate_template_id',
        'project-status-id' => 'project_status_id',
        'workflow-id' => 'workflow_id',
    ];

    foreach ($anchorOverrides as $optionKey => $configKey) {
        if (isset($options[$optionKey])) {
            $config->setAnchor($configKey, (int)$options[$optionKey]);
        }
    }
}

function validateConfig(TestConfig $config, TestOutput $output): void
{
    $output->header("Configuration Validation");

    $valid = true;

    // Check API key
    if ($config->getApiKey()) {
        $output->success("API Key: " . $config->getMaskedApiKey());
    } else {
        $output->error("API Key: NOT CONFIGURED");
        $valid = false;
    }

    // Check anchors
    $anchors = $config->getAnchors();
    $requiredAnchors = ['client_id', 'user_id'];
    $optionalAnchors = ['project_template_id', 'invoice_template_id', 'estimate_template_id', 'project_status_id', 'workflow_id'];

    foreach ($requiredAnchors as $anchor) {
        if (!empty($anchors[$anchor])) {
            $output->success(ucwords(str_replace('_', ' ', $anchor)) . ": " . $anchors[$anchor]);
        } else {
            $output->error(ucwords(str_replace('_', ' ', $anchor)) . ": NOT CONFIGURED (required)");
            $valid = false;
        }
    }

    foreach ($optionalAnchors as $anchor) {
        if (!empty($anchors[$anchor])) {
            $output->success(ucwords(str_replace('_', ' ', $anchor)) . ": " . $anchors[$anchor]);
        } else {
            $output->warning(ucwords(str_replace('_', ' ', $anchor)) . ": not configured (optional)");
        }
    }

    $output->line();

    if ($valid) {
        $output->success("Configuration is valid.");
    } else {
        $output->error("Configuration is incomplete. Some tests will be skipped.");
    }
}

