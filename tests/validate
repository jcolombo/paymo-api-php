function applyOverrides(TestConfig $config, array $options): void
{
    if (isset($options['k'])) {
        $config->setApiKey($options['k']);
    } elseif (isset($options['api-key'])) {
        $config->setApiKey($options['api-key']);
    }

    $anchorOverrides = [
        'client-id' => 'client_id',
        'user-id' => 'user_id',
        'project-template-id' => 'project_template_id',
        'invoice-template-id' => 'invoice_template_id',
        'estimate-template-id' => 'estimate_template_id',
        'project-status-id' => 'project_status_id',
        'workflow-id' => 'workflow_id',
    ];

    foreach ($anchorOverrides as $optionKey => $configKey) {
        if (isset($options[$optionKey])) {
            $config->setAnchor($configKey, (int)$options[$optionKey]);
        }
    }
}

function validateConfig(TestConfig $config, TestOutput $output): void
{
    $output->header("Configuration Validation");

    $valid = true;

    // Check API key
    if ($config->getApiKey()) {
        $output->success("API Key: " . $config->getMaskedApiKey());
    } else {
        $output->error("API Key: NOT CONFIGURED");
        $valid = false;
    }

    // Check anchors
    $anchors = $config->getAnchors();
    $requiredAnchors = ['client_id', 'user_id'];
    $optionalAnchors = ['project_template_id', 'invoice_template_id', 'estimate_template_id', 'project_status_id', 'workflow_id'];

    foreach ($requiredAnchors as $anchor) {
        if (!empty($anchors[$anchor])) {
            $output->success(ucwords(str_replace('_', ' ', $anchor)) . ": " . $anchors[$anchor]);
        } else {
            $output->error(ucwords(str_replace('_', ' ', $anchor)) . ": NOT CONFIGURED (required)");
            $valid = false;
        }
    }

    foreach ($optionalAnchors as $anchor) {
        if (!empty($anchors[$anchor])) {
            $output->success(ucwords(str_replace('_', ' ', $anchor)) . ": " . $anchors[$anchor]);
        } else {
            $output->warning(ucwords(str_replace('_', ' ', $anchor)) . ": not configured (optional)");
        }
    }

    $output->line();

    if ($valid) {
        $output->success("Configuration is valid.");
    } else {
        $output->error("Configuration is incomplete. Some tests will be skipped.");
    }
}

function showConfig(TestConfig $config, TestOutput $output): void
{
    $output->header("Current Configuration");

    // Config file location
    $configPath = $config->getConfigPath();
    if ($configPath) {
        $output->success("Config File: " . $configPath);
    } else {
        $output->warning("Config File: Using defaults (no config file found)");
    }
    $output->line();

    // Core settings
    $output->subHeader("Core Settings");
    $output->listItem("Testing Enabled: " . ($config->isTestingEnabled() ? "Yes" : "No"));
    $output->listItem("API Key: " . ($config->getApiKey() ? $config->getMaskedApiKey() : "NOT SET"));
    $output->listItem("Prefix: " . $config->getPrefix());
    $output->line();

    // Anchors
    $output->subHeader("Anchor IDs");
    $anchors = $config->getAnchors();
    $anchorLabels = [
        'client_id' => 'Client ID',
        'user_id' => 'User ID',
        'project_template_id' => 'Project Template ID',
        'invoice_template_id' => 'Invoice Template ID',
        'estimate_template_id' => 'Estimate Template ID',
        'project_status_id' => 'Project Status ID',
        'workflow_id' => 'Workflow ID',
    ];
    foreach ($anchorLabels as $key => $label) {
        $value = $anchors[$key] ?? null;
        if ($value) {
            $output->listItem("{$label}: {$value}");
        } else {
            $output->listItem("{$label}: not set");
        }
    }
    $output->line();

    // Modes
    $output->subHeader("Mode Settings");
    $modes = $config->getModes();
    $modeLabels = [
        'dry_run' => 'Dry Run',
        'verbose' => 'Verbose',
        'stop_on_failure' => 'Stop on Failure',
        'cleanup_on_failure' => 'Cleanup on Failure',
        'interactive' => 'Interactive',
    ];
    foreach ($modeLabels as $key => $label) {
        $value = $modes[$key] ?? false;
        $output->listItem("{$label}: " . ($value ? "Yes" : "No"));
    }
    $output->line();

    // Resources by Category
    $output->subHeader("Available Resources");
    $output->listItem("Safe CRUD: Client, Project, Tasklist, Task, Subtask, TimeEntry, etc.");
    $output->listItem("Read-Only: Company, Session, Workflow");
    $output->listItem("Configured Anchor: User, ProjectTemplate, InvoiceTemplate, etc.");
    $output->line();

    // Resource filtering
    $output->subHeader("Resource Filtering");
    $skip = $config->getSkippedResources();
    $only = $config->getOnlyResources();

    if (empty($only)) {
        $output->listItem("Only: (not set - all resources will run)");
    } else {
        $output->listItem("Only: " . implode(', ', $only));
    }

    if (empty($skip)) {
        $output->listItem("Skip: (none)");
    } else {
        $output->listItem("Skip: " . implode(', ', $skip));
    }
    $output->line();

    // Timeouts
    $output->subHeader("Timeouts");
    $timeouts = $config->getTimeouts();
    $output->listItem("Per Test: " . ($timeouts['per_test'] ?? 30) . "s");
    $output->listItem("Per Group: " . ($timeouts['per_group'] ?? 300) . "s");
    $output->listItem("Total: " . ($timeouts['total'] ?? 1800) . "s");
    $output->warning("Note: Timeouts are not currently enforced");
    $output->line();

    // Logging
    $output->subHeader("Logging");
    $logging = $config->getLogging();
    $output->listItem("Enabled: " . ($config->isLoggingEnabled() ? "Yes" : "No"));
    if ($config->isLoggingEnabled()) {
        $output->listItem("Log File: " . $config->getLogPath());
        $output->listItem("Log Level: " . $config->getLogLevel());
        $output->listItem("Include Timestamps: " . ($config->shouldIncludeTimestamps() ? "Yes" : "No"));
        $output->listItem("Include Stack Traces: " . ($config->shouldIncludeStackTraces() ? "Yes" : "No"));
    }
    $output->line();

    // Summary of what will run
    $output->subHeader("What Will Run");

    if (!empty($only)) {
        $output->listItem("Resources limited to: " . implode(', ', $only));
    } else {
        $output->listItem("All resources will be tested");
    }
    if (!empty($skip)) {
        $output->listItem("Resources excluded: " . implode(', ', $skip));
    }
}

function listTests(TestOutput $output): void
{
    $output->header("Available Resources (Resource-Centric Testing)");
    $output->line();
    $output->info("Each resource gets a complete test cycle:");
    $output->info("  - Property Discovery (compare API to SDK PROP_TYPES)");
    $output->info("  - Property Selection (verify each prop can be selected)");
    $output->info("  - CRUD operations (if supported)");
    $output->info("  - Where Operations (filtering)");
    $output->info("  - Include Relationships");
    $output->line();

    $categories = [
        'Safe CRUD (can create and delete)' => [
            'Client', 'Project', 'Tasklist', 'Task', 'Subtask',
            'TimeEntry', 'Milestone', 'Discussion', 'Comment', 'File',
            'Booking', 'Invoice', 'InvoiceItem', 'Estimate', 'EstimateItem',
            'Expense', 'Webhook'
        ],
        'Read-Only' => [
            'Company', 'Session', 'Workflow'
        ],
        'Configured Anchor (require pre-existing IDs)' => [
            'User', 'ProjectTemplate', 'InvoiceTemplate',
            'EstimateTemplate', 'ProjectStatus'
        ],
    ];

    foreach ($categories as $category => $resources) {
        $output->subHeader($category);
        foreach ($resources as $resource) {
            $output->listItem($resource);
        }
        $output->line();
    }

    $output->info("Use 'all' or specify resource names on command line.");
    $output->info("Use 'resources.only' in config to limit scope.");
}

function interactiveStartup(TestConfig $config, TestOutput $output, array &$resources): bool
{
    $output->banner();

    // Show warning
    $output->warning("This will make API calls to your Paymo account.");
    $output->info("Only test resources will be created and cleaned up.");
    $output->line();

    // Show configuration status
    $output->subHeader("Configuration Status");

    $apiKey = $config->getApiKey();
    if ($apiKey) {
        $output->success("API Key: " . $config->getMaskedApiKey());
    } else {
        $output->error("API Key: NOT CONFIGURED");
        $output->line();
        $output->error("Cannot proceed without API key.");
        return false;
    }

    $anchors = $config->getAnchors();

    $anchorLabels = [
        'client_id' => 'Test Client ID',
        'user_id' => 'Test User ID',
        'project_template_id' => 'Project Template ID',
        'invoice_template_id' => 'Invoice Template ID',
        'estimate_template_id' => 'Estimate Template ID',
        'project_status_id' => 'Project Status ID',
        'workflow_id' => 'Workflow ID',
    ];

    foreach ($anchorLabels as $key => $label) {
        if (!empty($anchors[$key])) {
            $output->success("$label: " . $anchors[$key]);
        } else {
            $output->warning("$label: NOT CONFIGURED");
        }
    }

    $output->line();

    // Show resource categories
    $output->subHeader("Resources to Test");

    $safeCrud = ['Client', 'Project', 'Tasklist', 'Task', 'Subtask', 'TimeEntry',
                 'Milestone', 'Discussion', 'Comment', 'File', 'Booking',
                 'Invoice', 'InvoiceItem', 'Estimate', 'EstimateItem', 'Expense', 'Webhook'];
    $readOnly = ['Company', 'Session', 'Workflow'];
    $anchored = ['User', 'ProjectTemplate', 'InvoiceTemplate', 'EstimateTemplate', 'ProjectStatus'];

    $output->listItem("Safe CRUD: " . count($safeCrud) . " resources");
    $output->listItem("Read-Only: " . count($readOnly) . " resources");
    $output->listItem("Configured Anchor: " . count($anchored) . " resources");

    // Show config restrictions
    $only = $config->getOnlyResources();
    $skip = $config->getSkippedResources();
    if (!empty($only)) {
        $output->info("Limited to: " . implode(', ', $only));
    }
    if (!empty($skip)) {
        $output->info("Skipping: " . implode(', ', $skip));
    }

    $output->line();

    // Confirm to proceed
    $output->info("Press ENTER to run all resources, or 'q' to quit.");
    $output->info("Or enter specific resource names (comma-separated):");

    $input = trim(fgets(STDIN));

    if (strtolower($input) === 'q') {
        return false;
    }

    // Parse user input for specific resources
    if (!empty($input) && strtolower($input) !== 'all') {
        $resources = array_map('trim', explode(',', $input));
    } else {
        // Run all resources - set to empty to trigger runAllTests()
        $resources = [];
    }

    return true;
}
