#!/usr/bin/env php
<?php
/**
 * Paymo API PHP SDK - Test Suite Validator
 *
 * CLI entry point for running the comprehensive test suite.
 * Validates all resources, properties, and operations against the Paymo API.
 *
 * This script is designed to NEVER crash or leave resources behind:
 * - Global exception handler catches all errors
 * - Shutdown function ensures cleanup runs
 * - Resource tracking ensures nothing is orphaned
 *
 * Usage: ./tests/validate [options] [groups...]
 *
 * @package    Jcolombo\PaymoApiPhp\Tests
 * @author     Joel Colombo <jc-dev@360psg.com>
 * @license    MIT
 */

// Ensure we're running from CLI
if (php_sapi_name() !== 'cli') {
    die("This script must be run from the command line.\n");
}

// Set error reporting
error_reporting(E_ALL);
ini_set('display_errors', '1');

// Bootstrap the test suite
require_once __DIR__ . '/bootstrap.php';

use Jcolombo\PaymoApiPhp\Tests\TestConfig;
use Jcolombo\PaymoApiPhp\Tests\ResourceTestRunner;
use Jcolombo\PaymoApiPhp\Tests\TestOutput;
use Jcolombo\PaymoApiPhp\Tests\TestResult;
use Jcolombo\PaymoApiPhp\Tests\TestLogger;
use Jcolombo\PaymoApiPhp\Paymo;

// Global variables for shutdown handler
$globalRunner = null;
$globalOutput = null;
$globalResults = null;
$globalLogger = null;

/**
 * Global exception handler - catches any uncaught exceptions
 */
set_exception_handler(function (Throwable $e) use (&$globalRunner, &$globalOutput, &$globalResults, &$globalLogger) {
    // Log to file
    if ($globalLogger) {
        $globalLogger->exception($e, 'Uncaught Exception');
    }

    if ($globalOutput) {
        $globalOutput->error("Uncaught Exception: " . $e->getMessage());
        $globalOutput->error("File: " . $e->getFile() . ":" . $e->getLine());
    } else {
        fwrite(STDERR, "FATAL ERROR: " . $e->getMessage() . "\n");
    }

    // Attempt emergency cleanup (SDK uses singleton connection)
    if ($globalRunner) {
        $globalRunner->emergencyCleanup();
    }

    // Display results if available
    if ($globalOutput && $globalResults) {
        $globalResults->finish();
        $globalOutput->displayResults($globalResults);
    }

    // Close logger
    if ($globalLogger) {
        $globalLogger->close();
    }

    exit(1);
});

/**
 * Global error handler - converts errors to exceptions
 */
set_error_handler(function ($severity, $message, $file, $line) {
    // Don't throw for suppressed errors
    if (!(error_reporting() & $severity)) {
        return false;
    }
    throw new ErrorException($message, 0, $severity, $file, $line);
});

/**
 * Shutdown handler - ensures cleanup runs even on fatal errors
 */
register_shutdown_function(function () use (&$globalRunner, &$globalOutput, &$globalResults, &$globalLogger) {
    $error = error_get_last();

    // Check if this is a fatal error
    if ($error !== null && in_array($error['type'], [E_ERROR, E_PARSE, E_CORE_ERROR, E_COMPILE_ERROR])) {
        // Log to file
        if ($globalLogger) {
            $globalLogger->error("Fatal Error: " . $error['message'] . " in " . $error['file'] . ":" . $error['line']);
        }

        if ($globalOutput) {
            $globalOutput->error("Fatal Error: " . $error['message']);
            $globalOutput->error("File: " . $error['file'] . ":" . $error['line']);
        } else {
            fwrite(STDERR, "FATAL ERROR: " . $error['message'] . "\n");
        }

        // Attempt emergency cleanup (SDK uses singleton connection)
        if ($globalRunner) {
            $globalRunner->emergencyCleanup();
        }

        // Display results if available
        if ($globalOutput && $globalResults) {
            $globalResults->finish();
            $globalOutput->displayResults($globalResults);
        }

        // Close logger
        if ($globalLogger) {
            $globalLogger->close();
        }
    }
});

// Parse command line arguments
$options = getopt('hc:k:vq', [
    'help',
    'config:',
    'api-key:',
    'client-id:',
    'user-id:',
    'project-template-id:',
    'invoice-template-id:',
    'estimate-template-id:',
    'project-status-id:',
    'workflow-id:',
    'dry-run',
    'verbose',
    'quiet',
    'stop-on-fail',
    'no-cleanup',
    'no-interactive',
    'reset-log',
    'list',
    'validate-config',
    'show-config',
    'json',
], $restIndex);

// Get non-option arguments (test groups)
$groups = array_slice($argv, $restIndex);

// Initialize output handler
$output = new TestOutput(
    isset($options['v']) || isset($options['verbose']),
    isset($options['q']) || isset($options['quiet']),
    isset($options['json'])
);

// Show help
if (isset($options['h']) || isset($options['help'])) {
    showHelp($output);
    exit(0);
}

// Load configuration
$configFile = $options['c'] ?? $options['config'] ?? null;
try {
    $config = new TestConfig($configFile);
} catch (Exception $e) {
    $output->error("Configuration Error: " . $e->getMessage());
    exit(1);
}

// Apply command line overrides
applyOverrides($config, $options);

// Set runtime options BEFORE logger initialization (so reset_log works)
$config->setRuntimeOption('dry_run', isset($options['dry-run']));
$config->setRuntimeOption('verbose', isset($options['v']) || isset($options['verbose']));
$config->setRuntimeOption('quiet', isset($options['q']) || isset($options['quiet']));
$config->setRuntimeOption('stop_on_failure', isset($options['stop-on-fail']));
$config->setRuntimeOption('cleanup_on_failure', !isset($options['no-cleanup']));
$config->setRuntimeOption('interactive', !isset($options['no-interactive']));
$config->setRuntimeOption('reset_log', isset($options['reset-log']));

// Initialize logger if enabled
$logger = null;
if ($config->isLoggingEnabled()) {
    $logger = new TestLogger($config);
    $output->setLogger($logger);
    $globalLogger = $logger;

    // Log configuration at start
    $logger->logConfiguration($config);
}

// Validate config only
if (isset($options['validate-config'])) {
    validateConfig($config, $output);
    exit(0);
}

// Show full config
if (isset($options['show-config'])) {
    showConfig($config, $output);
    exit(0);
}

// List available tests
if (isset($options['list'])) {
    listTests($output);
    exit(0);
}

// Check if testing is enabled
if (!$config->isTestingEnabled()) {
    $output->error("Testing is not enabled in configuration.");
    $output->info("Add '\"testing\": { \"enabled\": true, ... }' to your config file.");
    $output->info("Or use --config to specify a test configuration file.");
    exit(1);
}

// Interactive startup if enabled
if ($config->getRuntimeOption('interactive') && !$config->getRuntimeOption('quiet')) {
    if (!interactiveStartup($config, $output, $groups)) {
        $output->info("Test run cancelled.");
        exit(0);
    }
}

// Initialize and run tests
// Using try/finally to GUARANTEE cleanup and results display
$exitCode = 0;

try {
    // Use the new resource-centric test runner
    $runner = new ResourceTestRunner($config, $output, $logger);

    // Set global references for shutdown handler
    $globalRunner = $runner;
    $globalOutput = $output;
    $globalResults = $runner->getResults();

    // Establish connection for emergency cleanup capability
    if (!$config->getRuntimeOption('dry_run')) {
        try {
            $globalConnection = Paymo::connect($config->getApiKey());
        } catch (Exception $e) {
            $output->warning("Could not establish connection for emergency cleanup: " . $e->getMessage());
        }
    }

    // Determine which resources to run
    // $groups now contains resource names (e.g., Project, Task) not group names
    // Support comma-separated values (e.g., "Project,Task" or "Project Task")
    $resources = [];
    foreach ($groups as $group) {
        // Split on comma if present
        $parts = explode(',', $group);
        foreach ($parts as $part) {
            $trimmed = trim($part);
            if ($trimmed !== '') {
                $resources[] = $trimmed;
            }
        }
    }

    if (empty($resources) || in_array('all', $resources)) {
        $runner->runAllTests();
    } else {
        $runner->runResources($resources);
    }

    // Set exit code based on failures
    $exitCode = $runner->getResults()->hasFailures() ? 1 : 0;

} catch (Exception $e) {
    $output->error("Error during test execution: " . $e->getMessage());
    if ($config->getRuntimeOption('verbose')) {
        $output->error($e->getTraceAsString());
    }
    $exitCode = 1;

} finally {
    // ALWAYS display results, even if there was an error
    if (isset($runner)) {
        $results = $runner->getResults();
        $results->finish();
        $output->displayResults($results);
    }

    // Close logger and show log file location
    if ($logger) {
        $logger->close();
        if (!$config->getRuntimeOption('quiet') && !isset($options['json'])) {
            $output->info("Log file: " . $logger->getLogPath());
        }
    }
}

// Exit with appropriate code
exit($exitCode);

// ============================================================================
// Helper Functions
// ============================================================================

